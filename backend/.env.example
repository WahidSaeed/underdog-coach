# Copy this file to backend/.env and fill in your own values.
# backend/.env is gitignored (see root .gitignore's `.env` pattern) -
# never commit real credentials or model ids.
# See README.md "Backend: connecting to Bedrock" for how to get these.

# EU cross-region inference profile id from the Bedrock console
# (eu.anthropic.claude-...), not a bare model id.
BEDROCK_MODEL_ID=

# Named AWS CLI profile with Bedrock access (aws configure --profile ...)
AWS_PROFILE=underdog-coach

AWS_REGION=eu-central-1

# ARN of the Scenario agent's Bedrock AgentCore Runtime deployment
# (agentcore/, deployed via `agentcore deploy`). Leave empty to run the
# Scenario agent in-process instead.
SCENARIO_AGENT_RUNTIME_ARN=
